# ── GPS Decoder ───────────────────────────────────────────────────────────────

def _dms_to_decimal(dms, ref):
    """Convert degrees/minutes/seconds to decimal degrees."""
    try:
        d = float(dms[0])
        m = float(dms[1])
        s = float(dms[2])
        decimal = d + (m / 60.0) + (s / 3600.0)
        if ref in ['S', 'W']:
            decimal = -decimal
        return round(decimal, 7)
    except Exception:
        return None

def decode_gps(gps_info: dict) -> dict:
    result = {}
    try:
        lat_dms  = gps_info.get(2)
        lat_ref  = gps_info.get(1)
        lon_dms  = gps_info.get(4)
        lon_ref  = gps_info.get(3)
        alt      = gps_info.get(6)
        alt_ref  = gps_info.get(5)
        speed    = gps_info.get(13)
        bearing  = gps_info.get(17)
        timestamp= gps_info.get(7)
        datestamp= gps_info.get(29)

        if lat_dms and lat_ref:
            result['latitude']  = _dms_to_decimal(lat_dms, lat_ref)
            result['lat_ref']   = lat_ref
        if lon_dms and lon_ref:
            result['longitude'] = _dms_to_decimal(lon_dms, lon_ref)
            result['lon_ref']   = lon_ref
        if result.get('latitude') and result.get('longitude'):
            lat = result['latitude']
            lon = result['longitude']
            result['google_maps']  = f"https://maps.google.com/?q={lat},{lon}"
            result['openstreetmap']= f"https://www.openstreetmap.org/?mlat={lat}&mlon={lon}&zoom=16"
        if alt is not None:
            ref = -1 if alt_ref == b'\x01' else 1
            result['altitude_m'] = round(float(alt) * ref, 2)
        if speed:
            result['speed_kmh'] = round(float(speed) * 1.852, 2)
        if bearing:
            result['bearing_deg'] = round(float(bearing), 2)
        if timestamp:
            h, m, s = [float(x) for x in timestamp]
            result['gps_time_utc'] = f"{int(h):02d}:{int(m):02d}:{int(s):02d} UTC"
        if datestamp:
            result['gps_date'] = str(datestamp)
    except Exception:
        pass
    return result

# ── Pillow EXIF Extractor ─────────────────────────────────────────────────────

def extract_pillow(path: str) -> dict:
    data = {}
    if not PILLOW:
        return data
    try:
        img = Image.open(path)
        data['format']     = img.format
        data['mode']       = img.mode
        data['dimensions'] = f"{img.width} x {img.height} px"

        raw_exif = img._getexif() if hasattr(img, '_getexif') else None
        if not raw_exif:
            return data

        exif = {}
        gps_raw = {}
        for tag_id, value in raw_exif.items():
            tag = TAGS.get(tag_id, tag_id)
            if tag == 'GPSInfo':
                for gps_id, gps_val in value.items():
                    gps_raw[gps_id] = gps_val
            else:
                try:
                    exif[str(tag)] = str(value)[:200]
                except Exception:
                    pass

        data['exif'] = exif
        if gps_raw:
            data['gps'] = decode_gps(gps_raw)
    except Exception as e:
        data['pillow_error'] = str(e)
    return data

# ── ExifTool Extractor ────────────────────────────────────────────────────────

def extract_exiftool(path: str) -> dict:
    try:
        result = subprocess.run(
            ['exiftool', '-json', '-a', '-u', '-g', path],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0 and result.stdout:
            parsed = json.loads(result.stdout)
            if parsed:
                return parsed[0]
    except Exception:
        pass
    return {}

# ── URL Downloader ────────────────────────────────────────────────────────────

def download_image(url: str) -> str:
    """Download image from URL to /tmp, return local path."""
    try:
        filename = url.split('/')[-1].split('?')[0] or 'downloaded_image'
        if not any(filename.lower().endswith(ext) for ext in SUPPORTED):
            filename += '.jpg'
        dest = f"/tmp/metavenom_{filename}"
        headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)'}
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=15) as resp:
            with open(dest, 'wb') as f:
                f.write(resp.read())
        return dest
    except Exception as e:
        print(f"  [!] Download failed: {e}")
        return None

# ── Display ───────────────────────────────────────────────────────────────────

def display_results(path: str, pillow_data: dict, exif_data: dict):
    filename = Path(path).name

    if RICH:
        console.print(Rule(f"[bold red]  {filename}  [/bold red]", style="red"))
        console.print()

        # File basics
        stat = os.stat(path)
        basics = Table(box=box.SIMPLE, show_header=False, border_style="dim")
        basics.add_column("", style="dim", min_width=20)
        basics.add_column("", style="bold white")
        basics.add_row("File", filename)
        basics.add_row("Size", f"{stat.st_size:,} bytes ({stat.st_size/1024:.1f} KB)")
        basics.add_row("Format", pillow_data.get('format', exif_data.get('FileType', 'Unknown')))
        basics.add_row("Dimensions", pillow_data.get('dimensions', exif_data.get('ImageSize', 'Unknown')))
        console.print(Padding(basics, (0, 2)))

        # GPS — highest priority
        gps = pillow_data.get('gps', {})
        if not gps:
            # Try from exiftool
            lat  = exif_data.get('Composite', {}).get('GPSLatitude') or exif_data.get('GPSInfo', {}).get('GPSLatitude')
            lon  = exif_data.get('Composite', {}).get('GPSLongitude') or exif_data.get('GPSInfo', {}).get('GPSLongitude')
            if lat and lon:
                gps['latitude']   = lat
                gps['longitude']  = lon
                gps['google_maps']= f"https://maps.google.com/?q={lat},{lon}"

        if gps:
            console.print()
            console.print(Padding("[bold green]  ⚡ GPS DATA FOUND[/bold green]", (0, 2)))
            gps_table = Table(box=box.ROUNDED, border_style="green", show_header=False)
            gps_table.add_column("", style="dim", min_width=20)
            gps_table.add_column("", style="bold cyan")
            for k, v in gps.items():
                if 'maps' in k or 'openstreet' in k:
                    gps_table.add_row(k.replace('_', ' ').title(), f"[link]{v}[/link]")
                else:
                    gps_table.add_row(k.replace('_', ' ').title(), str(v))
            console.print(Padding(gps_table, (0, 2)))

        # Device & Camera info
        device_keys = ['Make', 'Model', 'Software', 'LensModel', 'LensMake',
                       'CameraSerialNumber', 'BodySerialNumber', 'InternalSerialNumber']
        exif_flat = pillow_data.get('exif', {})
        device_data = {k: exif_flat[k] for k in device_keys if k in exif_flat}

        # Also check exiftool output
        for section in exif_data.values():
            if isinstance(section, dict):
                for k in device_keys:
                    if k in section and k not in device_data:
                        device_data[k] = section[k]

        if device_data:
            console.print()
            console.print(Padding("[bold yellow]  📱 DEVICE FINGERPRINT[/bold yellow]", (0, 2)))
            dev_table = Table(box=box.SIMPLE, show_header=False, border_style="dim")
            dev_table.add_column("", style="dim", min_width=20)
            dev_table.add_column("", style="bold white")
