                dev_table.add_row(k, str(v))
            console.print(Padding(dev_table, (0, 2)))

        # Timestamps
        time_keys = ['DateTime', 'DateTimeOriginal', 'DateTimeDigitized',
                     'CreateDate', 'ModifyDate', 'GPSDateTime']
        time_data = {k: exif_flat[k] for k in time_keys if k in exif_flat}
        for section in exif_data.values():
            if isinstance(section, dict):
                for k in time_keys:
                    if k in section and k not in time_data:
                        time_data[k] = section[k]

        if time_data:
            console.print()
            console.print(Padding("[bold cyan]  🕐 TIMESTAMPS[/bold cyan]", (0, 2)))
            t_table = Table(box=box.SIMPLE, show_header=False, border_style="dim")
            t_table.add_column("", style="dim", min_width=22)
