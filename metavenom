# ── Report Writer ─────────────────────────────────────────────────────────────

def write_report(results: list, output_path: str):
    path = Path(output_path)
    path.parent.mkdir(parents=True, exist_ok=True)
    now = datetime.now().strftime("%Y-%m-%d %H:%M")
    lines = [f"# MetaVenom Report\n",
             f"| | |\n|---|---|\n| **Date** | {now} |\n| **Files** | {len(results)} |\n| **Tool** | MetaVenom v1.0.0 — CobraSEC |\n",
             "---\n"]

    for r in results:
        lines.append(f"## {Path(r['path']).name}\n")
        gps = r['pillow'].get('gps', {})
        if gps:
            lines.append("### GPS\n")
            for k, v in gps.items():
                lines.append(f"- **{k}:** {v}")
            lines.append("")
        exif = r['pillow'].get('exif', {})
        if exif:
            lines.append("### EXIF\n")
            for k, v in sorted(exif.items()):
                lines.append(f"- **{k}:** {v}")
            lines.append("")
        lines.append("---\n")

    path.write_text("\n".join(lines))
    if RICH:
        console.print(f"  [bold green]✔[/bold green]  Report saved → [bold cyan]{path}[/bold cyan]\n")
    else:
        print(f"  Report saved → {path}")

# ── Main ──────────────────────────────────────────────────────────────────────

def process_file(path: str) -> dict:
    pillow_data  = extract_pillow(path)
    exiftool_data = extract_exiftool(path)
    display_results(path, pillow_data, exiftool_data)
    return {'path': path, 'pillow': pillow_data, 'exiftool': exiftool_data}

def main():
    parser = argparse.ArgumentParser(
        description="MetaVenom — Image Metadata & OSINT Extractor",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument('--image',  metavar='FILE',  help='Single image file')
    parser.add_argument('--dir',    metavar='DIR',   help='Directory of images')
    parser.add_argument('--url',    metavar='URL',   help='Image URL to download and analyse')
    parser.add_argument('--output', metavar='FILE',  help='Save report to markdown file')
    args = parser.parse_args()

    print_banner()

    targets = []

    if args.image:
        targets.append(args.image)
    elif args.dir:
        d = Path(args.dir)
        targets = [str(p) for p in d.iterdir()
                   if p.suffix.lower() in SUPPORTED]
        if RICH:
            console.print(f"  [dim]Found {len(targets)} images in {args.dir}[/dim]\n")
    elif args.url:
        local = download_image(args.url)
        if local:
            targets.append(local)
    else:
        parser.print_help()
        return

    if not targets:
        if RICH:
            console.print("  [bold red]✘[/bold red]  No supported images found.")
        return

    results = []
    for t in targets:
        if not os.path.exists(t):
            if RICH:
                console.print(f"  [bold red]✘[/bold red]  File not found: {t}")
            continue
        results.append(process_file(t))

    if args.output and results:
        write_report(results, args.output)

    # Summary
    gps_count = sum(1 for r in results if r['pillow'].get('gps'))
    if RICH:
        console.print(Rule("[bold white]  Summary  [/bold white]", style="red"))
        console.print(f"\n  Files analysed : [bold white]{len(results)}[/bold white]")
        console.print(f"  GPS data found : [bold {'green' if gps_count else 'dim'}]{gps_count}[/bold {'green' if gps_count else 'dim'}]")
        console.print()
    else:
        print(f"\nFiles: {len(results)} | GPS found: {gps_count}")

if __name__ == '__main__':
    main()
